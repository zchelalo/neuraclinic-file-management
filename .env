ENVIRONMENT=development
SERVICE_NAME=neuraclinic-file-management
PORT=8000

DB_HOST=neuraclinic-file-management-db
DB_PORT=5432
DB_USER=postgres
DB_PASS=example
DB_NAME=neuraclinic-file-management
DB_SSLMODE=disable

GRPC_TLS_CERT_PATH=/app/certs/public_key.pem
GRPC_TLS_KEY_PATH=/app/certs/private_key.pem

STORAGE_PROVIDER=s3
STORAGE_BUCKET=neuraclinic-local-files
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://neuraclinic-file-management-minio:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=neuraclinic
STORAGE_SECRET_ACCESS_KEY=neuraclinic-secret
STORAGE_FORCE_PATH_STYLE=true
STORAGE_UPLOAD_URL_TTL=15m
STORAGE_DOWNLOAD_URL_TTL=15m

